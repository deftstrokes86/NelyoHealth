{
  "name": "@nelyohealth/mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./expo.entry.ts",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "start": "expo start --offline",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:expo": "expo config --type public"
  },
  "dependencies": {
    "expo": "56.0.12",
    "react": "19.2.7",
    "react-native": "0.85.3"
  }
}
