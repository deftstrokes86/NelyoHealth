{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "baseUrl": "../..",
    "paths": {
      "@nelyohealth/database": ["packages/database/lib/index.d.ts"],
      "@nelyohealth/domain": ["packages/domain/lib/index.d.ts"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
