{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "baseUrl": "../..",
    "paths": {
      "@nelyohealth/config": ["packages/config/src/index.ts"],
      "@nelyohealth/api-client": ["packages/api-client/src/index.ts"],
      "@nelyohealth/database": ["packages/database/lib/index.d.ts"],
      "@nelyohealth/domain": ["packages/domain/lib/index.d.ts"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
