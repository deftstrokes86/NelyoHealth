{
  "name": "@nelyohealth/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:nest": "node lib/nest/main.js"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/swagger": "11.4.4",
    "@nelyohealth/config": "workspace:*",
    "@nelyohealth/observability": "workspace:*",
    "@nelyohealth/platform-adapters": "workspace:*",
    "@nelyohealth/worker": "workspace:*",
    "hono": "4.12.25",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.27",
    "@types/express": "5.0.6"
  }
}
