{
  "name": "nelyohealth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@nelyohealth/browser-smoke",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:browser": "playwright test tests/e2e",
    "test:browser:headed": "playwright test tests/e2e --headed",
    "test:browser:ui": "playwright test tests/e2e --ui",
    "test:a11y": "playwright test tests/accessibility",
    "browser:cli:help": "playwright-cli --help",
    "browser:cli:install": "playwright-cli install-browser chromium",
    "browser:cli:open": "playwright-cli -s=nelyohealth-smoke open http://127.0.0.1:4173",
    "browser:cli:close": "playwright-cli -s=nelyohealth-smoke close",
    "browser:cli:cleanup": "playwright-cli -s=nelyohealth-smoke close && playwright-cli -s=nelyohealth-smoke delete-data",
    "build": "pnpm tokens:build && pnpm --filter @nelyohealth/content-registry build && pnpm --filter @nelyohealth/ui-foundation build && pnpm --filter @nelyohealth/design-foundation-preview build",
    "secret:scan": "node tools/checks/basic-secret-scan.mjs",
    "verify": "pnpm repository:verify",
    "tokens:build": "pnpm --filter @nelyohealth/design-tokens build",
    "tokens:check": "pnpm --filter @nelyohealth/design-tokens check",
    "content:validate": "pnpm --filter @nelyohealth/content-registry validate",
    "ui:build": "pnpm --filter @nelyohealth/ui-foundation build && pnpm --filter @nelyohealth/design-foundation-preview build",
    "ui:test": "vitest run packages",
    "ui:preview": "pnpm --filter @nelyohealth/design-foundation-preview dev",
    "ui:test:browser": "playwright test tests/e2e/design-foundation-preview.spec.ts --project=chromium",
    "ui:test:a11y": "playwright test tests/accessibility/design-foundation-preview.a11y.spec.ts --project=accessibility-chromium",
    "uiux:check": "node tools/ui-ux-pro-max/check-integrity.mjs",
    "uiux:review:foundation": "node tools/ui-ux-pro-max/run.mjs --label foundation-review --domain ux --stack react --query \"Warm Care Grid healthcare product foundation accessible motion content hierarchy privacy-preserving provider disclosure no dashboard imitation\"",
    "design:verify": "pnpm tokens:build && pnpm tokens:check && pnpm content:validate && pnpm ui:build && pnpm ui:test && pnpm uiux:check && pnpm ui:test:browser && pnpm ui:test:a11y",
    "community:verify": "node tools/checks/community-health.mjs",
    "actions:verify": "node tools/checks/github-actions-pinning.mjs",
    "deps:policy": "node tools/checks/package-policy.mjs",
    "deps:audit": "pnpm audit --audit-level high",
    "deps:licenses": "node tools/checks/dependency-license-policy.mjs",
    "deps:inventory": "node tools/reports/dependency-inventory.mjs",
    "deps:outdated": "node tools/checks/outdated-informational.mjs",
    "deps:verify": "pnpm deps:policy && pnpm deps:licenses && pnpm deps:inventory",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main || node tools/checks/changeset-policy.mjs --status-only",
    "release:version": "changeset version",
    "release:check": "node tools/checks/release-readiness.mjs",
    "release:inventory": "node tools/reports/dependency-inventory.mjs",
    "repository:verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm test:browser && pnpm test:a11y && pnpm build && pnpm secret:scan && pnpm community:verify && pnpm actions:verify && pnpm deps:verify && pnpm changeset:status && pnpm release:check"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@playwright/cli": "0.1.14",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.5.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "motion": "12.41.0",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "turbo": "2.10.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  }
}
