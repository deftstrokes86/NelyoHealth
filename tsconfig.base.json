{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@nelyohealth/config": ["packages/config/src/index.ts"],
      "@nelyohealth/api-client": ["packages/api-client/src/index.ts"],
      "@nelyohealth/database": ["packages/database/src/index.ts"]
    },
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tools/**/*.ts",
    "tools/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.mjs",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "lib", ".artifacts"]
}
